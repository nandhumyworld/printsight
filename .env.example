# Place this file one level above the project as ../.env

# Database
DATABASE_URL=postgresql://printsight:password@localhost:5432/printsight

# Auth — SECRET_KEY must be a random 32+ char string in production
SECRET_KEY=change-me-minimum-32-chars-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:8001
